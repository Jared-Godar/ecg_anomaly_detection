classes: {
  standard-card: {
    style: {
      fill: "#EAF2FB"
      stroke: "#7096C4"
      stroke-width: 2
      border-radius: 8
      font-color: "#0F172A"
    }
  }
  emphasis-card: {
    style: {
      fill: "#FFFFFF"
      stroke: "#7096C4"
      stroke-width: 2
      border-radius: 8
      font-color: "#0F172A"
    }
  }
  zone-container: {
    style: {
      fill: "#F4F8FD"
      stroke: "#8FAFD4"
      stroke-width: 2
      stroke-dash: 3
      border-radius: 8
      font-color: "#0F172A"
      bold: true
    }
  }
  pipeline-lane: {
    style: {
      fill: "#F1F5F9"
      stroke: "#CBD5E1"
      stroke-width: 2
      border-radius: 12
      font-color: "#0F172A"
    }
  }
  badge: {
    style: {
      fill: "#DBE8F8"
      stroke: "#3E6DB5"
      stroke-width: 2
      font-color: "#0F172A"
      bold: true
    }
    shape: circle
    width: 28
    height: 28
  }
  blocked-card: {
    style: {
      fill: "#FEF3C7"
      stroke: "#B45309"
      stroke-width: 2
      border-radius: 24
      font-color: "#0F172A"
    }
  }
  merged-card: {
    style: {
      fill: "#C7DBF5"
      stroke: "#3E6DB5"
      stroke-width: 2
      border-radius: 24
      font-color: "#0F172A"
    }
  }
  closed-card: {
    style: {
      fill: "#E2E8F0"
      stroke: "#64748B"
      stroke-width: 2
      border-radius: 24
      font-color: "#0F172A"
    }
  }
  pill-card: {
    style: {
      fill: "#EAF2FB"
      stroke: "#7096C4"
      stroke-width: 2
      border-radius: 24
      font-color: "#0F172A"
    }
  }
  primary-flow: {
    style: {
      stroke: "#3E6DB5"
      stroke-width: 2
      font-color: "#475569"
    }
  }
  secondary-flow: {
    style: {
      stroke: "#64748B"
      stroke-width: 2
      stroke-dash: 4
      font-color: "#475569"
    }
  }
  annotation: {
    style: {
      italic: true
      font-color: "#475569"
      stroke: transparent
      fill: transparent
    }
  }
}
